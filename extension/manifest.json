{
  "manifest_version": 3,
  "name": "SuperTroopers",
  "version": "0.1.0",
  "description": "AI-powered reverse recruiting command center",
  "minimum_chrome_version": "116",
  "permissions": [
    "activeTab",
    "storage",
    "alarms",
    "tabs",
    "notifications",
    "webNavigation"
  ],
  "host_permissions": [
    "http://localhost:8055/*",
    "http://localhost:8056/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "assets/icons/icon-16.png",
      "32": "assets/icons/icon-32.png",
      "48": "assets/icons/icon-48.png",
      "128": "assets/icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.indeed.com/*",
        "*://*.linkedin.com/jobs/*",
        "*://*.glassdoor.com/job-listing/*",
        "*://*.glassdoor.com/Job/*",
        "*://*.ziprecruiter.com/jobs/*",
        "*://*.dice.com/job-detail/*",
        "*://*.builtin.com/job/*",
        "*://*.builtin.com/jobs/*",
        "*://*.joinhandshake.com/stu/jobs/*",
        "*://*.joinhandshake.com/emp/jobs/*",
        "*://*.joinhandshake.com/postings/*",
        "*://*.monster.com/job-openings/*",
        "*://*.monster.com/jobs/*",
        "*://*.careerbuilder.com/job/*",
        "*://*.simplyhired.com/job/*",
        "*://*.simplyhired.com/search*",
        "*://*.wellfound.com/jobs/*",
        "*://*.wellfound.com/l/*",
        "*://*.otta.com/jobs/*",
        "*://*.levels.fyi/jobs/*",
        "*://*.theladders.com/job/*",
        "*://*.weworkremotely.com/remote-jobs/*",
        "*://*.flexjobs.com/publicjobs/*",
        "*://*.flexjobs.com/jobs/*",
        "*://*.remotive.com/remote-jobs/*",
        "*://*.usajobs.gov/job/*",
        "*://*.usajobs.gov/GetJob/*",
        "*://*.welcometothejungle.com/companies/*",
        "*://*.welcometothejungle.com/jobs/*",
        "*://*.themuse.com/jobs/*",
        "*://*.idealist.org/jobs/*",
        "*://*.idealist.org/opportunity/*",
        "*://*.governmentjobs.com/careers/*",
        "*://*.governmentjobs.com/jobs/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  }
}
