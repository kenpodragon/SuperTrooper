# SuperTroopers Backend Environment
# Copy this to .env and fill in your values

# Database
DB_HOST=localhost
DB_PORT=5555
DB_NAME=supertroopers
DB_USER=supertroopers
DB_PASSWORD=your-secure-password-here

# Connection string
DATABASE_URL=postgresql://supertroopers:your-secure-password-here@localhost:5432/supertroopers

# Embeddings (at least one required for RAG features)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Flask
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=change-me-in-production
